{
  "name": "kimchi-lander-sim-2d-workspace",
  "private": true,
  "scripts": {
    "bootstrap": "./scripts/bootstrap.sh",
    "start": "./scripts/start-app.sh",
    "dev": "./scripts/start-app.sh --dev",
    "setup": "./scripts/start-app.sh --setup-only",
    "start:built": "npm run electron:start",
    "python:test": "sh -lc '. .venv/bin/activate && pytest -q'",
    "bridge:list-presets": "sh -lc '. .venv/bin/activate && python -m lander_sim bridge list-presets'",
    "bridge:get-stable-hover": "sh -lc '. .venv/bin/activate && python -m lander_sim bridge get-preset stable_hover.json'",
    "electron:install": "npm --prefix electron-app install",
    "electron:dev": "npm --prefix electron-app run dev",
    "electron:build": "npm --prefix electron-app run build",
    "electron:start": "npm --prefix electron-app run start",
    "electron:smoke": "node ./scripts/electron-smoke.mjs"
  }
}
